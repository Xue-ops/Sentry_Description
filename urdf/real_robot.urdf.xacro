<?xml version="1.0"?>
<robot name="real_robot" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:arg name="base_frame" default="odom"/>
  <xacro:arg name="robot_base_frame" default="robot_base"/>
  <xacro:arg name="cmd_topic" default="/cmd_vel"/>
  <xacro:arg name="odom_topic" default="/odom"/>
  <xacro:arg name="odom_frame" default="odom"/>
  <xacro:arg name="odin1_frame" default="odin1_base_link"/>
  <xacro:arg name="livox_frame" default="livox_frame"/>
  <xacro:arg name="odin1_cloud_topic" default="/odin1/cloud_slam"/>
  <xacro:arg name="odin1_cloud_frame" default="odin1_base_link"/>
  <xacro:arg name="livox_cloud_topic" default="livox/lidar"/>
  <xacro:arg name="wheel_prefix" default=""/>

  <xacro:property name="base_size" value="0.45"/>
  <xacro:property name="base_height" value="0.18"/>
  <xacro:property name="base_z" value="0.16"/>

  <xacro:property name="wheel_radius" value="0.10"/>
  <xacro:property name="wheel_width" value="0.04"/>
  <xacro:property name="wheel_xy_offset" value="0.19"/>
  <xacro:property name="wheel_z_offset" value="0.10"/>
  <xacro:property name="wheel_mount_yaw" value="0.785398"/>
  <xacro:property name="wheel_forward_friction" value="1.5"/>
  <xacro:property name="wheel_side_friction" value="0.05"/>

  <xacro:property name="odin1_x" value="-0.02897"/>
  <xacro:property name="odin1_y" value="0.11458"/>
  <xacro:property name="odin1_z" value="0.24799"/>
  <xacro:property name="odin1_roll" value="0.0"/>
  <xacro:property name="odin1_pitch" value="0.0"/>
  <xacro:property name="odin1_yaw" value="1.57079632679"/>

  <xacro:property name="livox_x" value="0.0025"/>
  <xacro:property name="livox_y" value="-0.13509"/>
  <xacro:property name="livox_z" value="0.29325"/>
  <xacro:property name="livox_roll" value="0.0"/>
  <xacro:property name="livox_pitch" value="-0.78539816339"/>
  <xacro:property name="livox_yaw" value="-1.57079632679"/>

  <xacro:macro name="real_omni_robot" params="base_frame robot_base_frame cmd_topic odom_topic odom_frame odin1_frame livox_frame odin1_cloud_topic odin1_cloud_frame livox_cloud_topic wheel_prefix">
    <!-- ===================== -->
    <!-- base link -->
    <!-- ===================== -->
    <link name="${robot_base_frame}">
      <visual>
        <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
        <geometry>
          <box size="${base_size} ${base_size} ${base_height}"/>
        </geometry>
        <material name="${wheel_prefix}base_gray">
          <color rgba="0.18 0.20 0.22 1.0"/>
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
        <geometry>
          <box size="${base_size} ${base_size} ${base_height}"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
        <mass value="8.0"/>
        <inertia
          ixx="0.15" ixy="0.0" ixz="0.0"
          iyy="0.15" iyz="0.0"
          izz="0.15"/>
      </inertial>
    </link>

    <!-- ===================== -->
    <!-- four omni wheels -->
    <!-- ===================== -->
    <xacro:macro name="omni_wheel" params="prefix x y wheel_yaw roller_yaw">
      <link name="${wheel_prefix}${prefix}_wheel_link">
        <visual>
          <origin xyz="0 0 0" rpy="1.5708 0 0"/>
          <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
          </geometry>
          <material name="${wheel_prefix}${prefix}_wheel_black">
            <color rgba="0.02 0.02 0.02 1.0"/>
          </material>
        </visual>

        <collision>
          <origin xyz="0 0 0" rpy="1.5708 0 0"/>
          <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
          </geometry>
        </collision>

        <inertial>
          <mass value="0.5"/>
          <inertia
            ixx="0.001" ixy="0.0" ixz="0.0"
            iyy="0.001" iyz="0.0"
            izz="0.001"/>
        </inertial>
      </link>

      <joint name="${wheel_prefix}${prefix}_wheel_joint" type="continuous">
        <parent link="${robot_base_frame}"/>
        <child link="${wheel_prefix}${prefix}_wheel_link"/>
        <origin xyz="${x} ${y} ${wheel_z_offset}" rpy="0 0 ${wheel_yaw}"/>
        <axis xyz="0 1 0"/>
      </joint>

      <link name="${wheel_prefix}${prefix}_roller_link">
        <visual>
          <origin xyz="0 0 0" rpy="0.7854 0 ${roller_yaw}"/>
          <geometry>
            <box size="0.11 0.02 0.02"/>
          </geometry>
          <material name="${wheel_prefix}${prefix}_roller_silver">
            <color rgba="0.65 0.65 0.65 1.0"/>
          </material>
        </visual>

        <collision>
          <origin xyz="0 0 0" rpy="0.7854 0 ${roller_yaw}"/>
          <geometry>
            <box size="0.11 0.02 0.02"/>
          </geometry>
        </collision>

        <inertial>
          <mass value="0.05"/>
          <inertia
            ixx="0.00005" ixy="0.0" ixz="0.0"
            iyy="0.00005" iyz="0.0"
            izz="0.00005"/>
        </inertial>
      </link>

      <joint name="${wheel_prefix}${prefix}_roller_fixed_joint" type="fixed">
        <parent link="${wheel_prefix}${prefix}_wheel_link"/>
        <child link="${wheel_prefix}${prefix}_roller_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </joint>

      <gazebo reference="${wheel_prefix}${prefix}_wheel_link">
        <material>Gazebo/Black</material>
        <fdir1>1 0 0</fdir1>
        <mu1>${wheel_forward_friction}</mu1>
        <mu2>${wheel_side_friction}</mu2>
      </gazebo>

      <gazebo reference="${wheel_prefix}${prefix}_roller_link">
        <material>Gazebo/Grey</material>
        <mu1>0.05</mu1>
        <mu2>0.05</mu2>
      </gazebo>
    </xacro:macro>

    <xacro:omni_wheel
      prefix="front_left"
      x="${wheel_xy_offset}"
      y="${wheel_xy_offset}"
      wheel_yaw="${-wheel_mount_yaw}"
      roller_yaw="0.7854"/>
    <xacro:omni_wheel
      prefix="front_right"
      x="${wheel_xy_offset}"
      y="${-wheel_xy_offset}"
      wheel_yaw="${wheel_mount_yaw}"
      roller_yaw="-0.7854"/>
    <xacro:omni_wheel
      prefix="rear_left"
      x="${-wheel_xy_offset}"
      y="${wheel_xy_offset}"
      wheel_yaw="${wheel_mount_yaw}"
      roller_yaw="-0.7854"/>
    <xacro:omni_wheel
      prefix="rear_right"
      x="${-wheel_xy_offset}"
      y="${-wheel_xy_offset}"
      wheel_yaw="${-wheel_mount_yaw}"
      roller_yaw="0.7854"/>

    <!-- ===================== -->
    <!-- lidar/camera links -->
    <!-- ===================== -->
    <link name="${odin1_frame}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.055" length="0.06"/>
        </geometry>
        <material name="${wheel_prefix}odin1_red">
          <color rgba="0.85 0.12 0.10 1.0"/>
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.055" length="0.06"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="0.2"/>
        <inertia
          ixx="0.0005" ixy="0.0" ixz="0.0"
          iyy="0.0005" iyz="0.0"
          izz="0.0005"/>
      </inertial>
    </link>

    <joint name="${robot_base_frame}_to_${odin1_frame}" type="fixed">
      <parent link="${robot_base_frame}"/>
      <child link="${odin1_frame}"/>
      <origin xyz="${odin1_x} ${odin1_y} ${odin1_z}" rpy="${odin1_roll} ${odin1_pitch} ${odin1_yaw}"/>
    </joint>

    <link name="${livox_frame}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.075 0.075 0.05"/>
        </geometry>
        <material name="${wheel_prefix}livox_blue">
          <color rgba="0.10 0.32 0.85 1.0"/>
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.075 0.075 0.05"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="0.2"/>
        <inertia
          ixx="0.0005" ixy="0.0" ixz="0.0"
          iyy="0.0005" iyz="0.0"
          izz="0.0005"/>
      </inertial>
    </link>

    <joint name="${robot_base_frame}_to_${livox_frame}" type="fixed">
      <parent link="${robot_base_frame}"/>
      <child link="${livox_frame}"/>
      <origin xyz="${livox_x} ${livox_y} ${livox_z}" rpy="${livox_roll} ${livox_pitch} ${livox_yaw}"/>
    </joint>

    <!-- ===================== -->
    <!-- Gazebo lidar sensors -->
    <!-- PointCloud2 -->
    <!-- ===================== -->
    <gazebo reference="${odin1_frame}">
      <sensor name="${wheel_prefix}odin1_pointcloud_lidar" type="gpu_ray">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <visualize>false</visualize>

        <pose>0 0 0 0 0 0</pose>

        <ray>
          <scan>
            <horizontal>
              <samples>120</samples>
              <resolution>1</resolution>
              <min_angle>-1.047198</min_angle>
              <max_angle>1.047198</max_angle>
            </horizontal>

            <vertical>
              <samples>16</samples>
              <resolution>1</resolution>
              <min_angle>-0.392699</min_angle>
              <max_angle>0.392699</max_angle>
            </vertical>
          </scan>

          <range>
            <min>0.1</min>
            <max>20.0</max>
            <resolution>0.02</resolution>
          </range>

          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>

        <plugin name="${wheel_prefix}odin1_gazebo_ros_pointcloud" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <namespace>/</namespace>
            <remapping>~/out:=${odin1_cloud_topic}</remapping>
          </ros>
          <output_type>sensor_msgs/PointCloud2</output_type>
          <frame_name>${odin1_cloud_frame}</frame_name>
        </plugin>
      </sensor>
    </gazebo>

    <gazebo reference="${livox_frame}">
      <sensor name="${wheel_prefix}mid360_pointcloud_lidar" type="gpu_ray">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <visualize>false</visualize>

        <pose>0 0 0 0 0 0</pose>

        <ray>
          <scan>
            <horizontal>
              <samples>180</samples>
              <resolution>1</resolution>
              <min_angle>-1.570796</min_angle>
              <max_angle>1.570796</max_angle>
            </horizontal>

            <vertical>
              <samples>16</samples>
              <resolution>1</resolution>
              <min_angle>-1.570796</min_angle>
              <max_angle>0.392699</max_angle>
            </vertical>
          </scan>

          <range>
            <min>0.1</min>
            <max>20.0</max>
            <resolution>0.02</resolution>
          </range>

          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>

        <plugin name="${wheel_prefix}mid360_gazebo_ros_pointcloud" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <namespace>/</namespace>
            <remapping>~/out:=${livox_cloud_topic}</remapping>
          </ros>
          <output_type>sensor_msgs/PointCloud2</output_type>
          <frame_name>${livox_frame}</frame_name>
        </plugin>
      </sensor>
    </gazebo>

    <gazebo reference="${robot_base_frame}">
      <material>Gazebo/Grey</material>
    </gazebo>

    <!-- ===================== -->
    <!-- Gazebo omni drive plugin -->
    <!-- ===================== -->
    <gazebo>
      <plugin name="${wheel_prefix}omni_drive_controller" filename="libgazebo_ros_planar_move.so">
        <ros>
          <namespace>/</namespace>
          <remapping>cmd_vel:=${cmd_topic}</remapping>
          <remapping>odom:=${odom_topic}</remapping>
        </ros>

        <command_topic>${cmd_topic}</command_topic>
        <odometry_topic>${odom_topic}</odometry_topic>
        <odometry_frame>${odom_frame}</odometry_frame>
        <robot_base_frame>${robot_base_frame}</robot_base_frame>

        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>

        <update_rate>50</update_rate>
      </plugin>
    </gazebo>
  </xacro:macro>

  <xacro:real_omni_robot
    base_frame="$(arg base_frame)"
    robot_base_frame="$(arg robot_base_frame)"
    cmd_topic="$(arg cmd_topic)"
    odom_topic="$(arg odom_topic)"
    odom_frame="$(arg odom_frame)"
    odin1_frame="$(arg odin1_frame)"
    livox_frame="$(arg livox_frame)"
    odin1_cloud_topic="$(arg odin1_cloud_topic)"
    odin1_cloud_frame="$(arg odin1_cloud_frame)"
    livox_cloud_topic="$(arg livox_cloud_topic)"
    wheel_prefix="$(arg wheel_prefix)"/>

</robot>
